# FlowDesk Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file to git!

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development  # development, staging, or production

# ============================================================================
# DATABASE
# ============================================================================
# Generate with: openssl rand -hex 16 for password
DATABASE_URL=postgresql+psycopg2://flowdesk_user:YOUR_SECURE_PASSWORD_HERE@flowdesk-db:5432/flowdesk

# ============================================================================
# SECURITY - JWT & Authentication
# ============================================================================
# Generate a secure 32+ character key:
# openssl rand -hex 32
SECRET_KEY=your_secure_random_32_char_minimum_secret_key_here_change_me_before_production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
# In production, set this to your frontend domain(s)
# Examples: https://app.flowdesk.com,https://dashboard.flowdesk.com
ALLOWED_ORIGINS=http://localhost:3000

# ============================================================================
# SMTP - Email Configuration
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_specific_password_here
SMTP_FROM=noreply@flowdesk.app
SMTP_TLS=true

# ============================================================================
# APPLICATION
# ============================================================================
APP_NAME=FlowDesk
FRONTEND_URL=http://localhost:3000
MEDIA_DIR=media

# Comma-separated list of admin emails (for initial setup)
SUPER_ADMIN_EMAIL=admin@example.com

# ============================================================================
# SECURITY - HTTPS Enforcement
# ============================================================================
REQUIRE_HTTPS=true  # Set to true in production
